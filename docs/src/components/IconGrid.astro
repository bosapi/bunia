---
import { icons } from "../../../registry/components/ui/icon/icons.ts";

const groups: Record<string, string[]> = {
    Navigation: [],
    Actions: [],
    UI: [],
    Layout: [],
    Status: [],
    Content: [],
    User: [],
    Communication: [],
    Misc: [],
};

// Map icons to groups based on the comments in icons.ts
const groupMap: Record<string, string> = {
    "arrow-left": "Navigation", "arrow-right": "Navigation", "arrow-up": "Navigation", "arrow-down": "Navigation",
    "chevron-left": "Navigation", "chevron-right": "Navigation", "chevron-up": "Navigation", "chevron-down": "Navigation",
    check: "Actions", x: "Actions", plus: "Actions", minus: "Actions",
    search: "Actions", filter: "Actions", "ellipsis-vertical": "Actions",
    menu: "UI", sun: "UI", moon: "UI", eye: "UI", "eye-off": "UI",
    settings: "UI", bell: "UI", trash: "UI", edit: "UI", copy: "UI",
    "panel-left": "Layout", "panel-right": "Layout", "layout-dashboard": "Layout", columns: "Layout",
    "circle-alert": "Status", "circle-check": "Status", "circle-x": "Status", info: "Status", loader: "Status",
    file: "Content", folder: "Content", image: "Content", download: "Content", upload: "Content",
    user: "User", users: "User", "log-out": "User", "log-in": "User",
    "message-square": "Communication", mail: "Communication",
    home: "Misc", "external-link": "Misc", link: "Misc", star: "Misc",
    heart: "Misc", globe: "Misc", calendar: "Misc", clock: "Misc",
};

for (const name of Object.keys(icons)) {
    const group = groupMap[name] || "Misc";
    groups[group].push(name);
}

const svgAttrs = `xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"`;
---

{Object.entries(groups).filter(([_, names]) => names.length > 0).map(([group, names]) => (
    <div>
        <h3>{group}</h3>
        <div class="icon-grid">
            {names.map((name) => (
                <button
                    class="icon-cell"
                    data-icon-name={name}
                    title={name}
                >
                    <Fragment set:html={`<svg ${svgAttrs}>${icons[name as keyof typeof icons]}</svg>`} />
                </button>
            ))}
        </div>
    </div>
))}

<div id="icon-toast" class="icon-toast">Copied!</div>

<style>
    .icon-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, 56px);
        gap: 8px;
        margin: 16px 0 24px;
    }
    .icon-cell {
        all: unset;
        box-sizing: border-box;
        width: 56px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 8px;
        background: transparent;
        color: var(--sl-color-text);
        cursor: pointer;
        transition: all 0.15s;
    }
    .icon-cell:hover {
        border-color: var(--sl-color-accent);
        background: var(--sl-color-accent-low);
    }
    .icon-toast {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%) translateY(80px);
        background: var(--sl-color-text);
        color: var(--sl-color-bg);
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        pointer-events: none;
        opacity: 0;
        transition: all 0.25s ease;
        z-index: 100;
    }
    .icon-toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }
</style>

<script>
    document.querySelectorAll('.icon-cell').forEach((btn) => {
        btn.addEventListener('click', () => {
            const name = (btn as HTMLElement).dataset.iconName!;
            navigator.clipboard.writeText(name);
            const toast = document.getElementById('icon-toast')!;
            toast.textContent = `Copied "${name}"`;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 1500);
        });
    });
</script>
